# ======================================
# Dar Baraï – Variables d'environnement
# ======================================
# Copier ce fichier en .env et remplir les valeurs

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe ---
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (emails transactionnels) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=reservations@darbarai.com
RESEND_FROM_NAME="Dar Baraï Marrakech"

# --- Site ---
NUXT_PUBLIC_SITE_URL=https://www.darbarai.com

# --- Contact (bouton WhatsApp sur page de réservation) ---
NUXT_PUBLIC_CONTACT_WHATSAPP=33600000000   # sans le +, ex: 33612345678
NUXT_PUBLIC_CONTACT_EMAIL=reservations@darbarai.com

# --- Google OAuth (configuré dans Supabase Dashboard) ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
