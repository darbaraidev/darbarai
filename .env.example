# ======================================
# Dar Baraï – Variables d'environnement
# ======================================
# Copier ce fichier en .env et remplir les valeurs

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...   # anon/public key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Stripe ---
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (emails transactionnels) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=reservations@darbarai.com
RESEND_FROM_NAME="Dar Barai"
RESEND_NEWSLETTER_EMAIL=newsletter@darbarai.com  # expéditeur newsletter (optionnel)

# --- Admin ---
ADMIN_EMAIL=nathalie@darbarai.com

# --- Supabase Auth Hook ---
# Chaîne aléatoire longue, doit être identique dans le dashboard Supabase
SUPABASE_HOOK_SECRET=change_me_with_a_long_random_string

# --- Cloudinary (stockage images) ---
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx

# --- Site ---
NUXT_PUBLIC_SITE_URL=https://www.darbarai.com

# --- Contact (bouton WhatsApp sur page de réservation) ---
NUXT_PUBLIC_CONTACT_WHATSAPP=33600000000   # sans le +, ex: 33612345678
NUXT_PUBLIC_CONTACT_EMAIL=contact@darbarai.com
